# ── Supabase ──────────────────────────────────────────────────────────────────
# From: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...your-anon-key
SUPABASE_SERVICE_ROLE_KEY=eyJ...your-service-role-key

# ── Site ───────────────────────────────────────────────────────────────────────
# Use http://localhost:3000 in development, https://zevfelix.com in production
NEXT_PUBLIC_SITE_URL=https://zevfelix.com

# ── Email (Resend) ─────────────────────────────────────────────────────────────
# From: resend.com → API Keys
# Required for: contact form notifications, newsletter sends, unsubscribe links
RESEND_API_KEY=re_your_key_here

# The email address where contact form submissions are forwarded
NOTIFICATION_EMAIL=zev@example.com
